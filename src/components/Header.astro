---
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="border-b border-themed">
  <nav class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="https://buxo.ai" class="flex items-center gap-2 text-themed hover:text-accent transition-colors">
      <img src="/logo-dark.png" alt="Buxo" height="28" class="dark:hidden" />
      <img src="/logo.png" alt="Buxo" height="28" class="hidden dark:block" />
    </a>
    <div class="flex items-center gap-4">
      <a href="/" class="text-sm text-themed-muted hover:text-accent transition-colors">Posts</a>
      <a href="/rss.xml" class="text-sm text-themed-muted hover:text-accent transition-colors">RSS</a>
      <a href="https://buxo.ai" class="text-sm text-themed-muted hover:text-accent transition-colors" target="_blank" rel="noopener">buxo.ai</a>
      <ThemeToggle />
    </div>
  </nav>
</header>
